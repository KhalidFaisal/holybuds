generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Product {
  id          String      @id @default(cuid())
  name        String
  category    String      // FLOWER or EDIBLE
  price       Float
  weight      String?     // e.g. "3.5g", "1g", "7g", "1pc", "10pc"
  description String      @default("")
  image       String      @default("")
  images      String      @default("[]")
  stock       Int         @default(0)
  featured    Boolean     @default(false)
  isVisible   Boolean     @default(true)
  effects     String      @default("[]")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerName    String
  customerPhone   String
  deliveryMethod  String      @default("PICKUP") // PICKUP, DELIVERY
  deliveryAddress String      @default("")
  status          String      @default("PENDING") // PENDING, PROCESSING, READY, COMPLETED, CANCELLED
  total           Float
  discountName    String?
  discountAmount  Float       @default(0)
  notes           String      @default("")
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id])
  pointsEarned    Int         @default(0)
  pointsUsed      Int         @default(0)
  rewardUsed      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model Discount {
  id               String   @id @default(cuid())
  name             String
  type             String   // PERCENTAGE, FIXED
  value            Float
  minOrderValue    Float    @default(0)
  targetType       String   // ENTIRE_ORDER, CATEGORY, SPECIFIC_PRODUCTS
  targetCategory   String?  // FLOWER, EDIBLE
  targetProductIds String?  // JSON array of strings
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Banner {
  id              String   @id @default(cuid())
  title           String   @default("")
  desktopImage    String
  mobileImage     String
  link            String   @default("")
  isActive        Boolean  @default(true)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SiteSettings {
  id                String  @id @default("global")
  sitePassword      String  @default("Holymoly")
  adminPasswordHash String?
  timezone          String  @default("UTC")
  chatbotPrompt     String  @default("You are a helpful, friendly budtender at Elevated Dispensary. Recommend products from our inventory based on the user's needs. Be concise, polite, and use a chill tone.")
  aiModel           String  @default("openrouter/free")
  openRouterApiKey  String?
  groqApiKey        String?
  loyaltyEnabled    Boolean @default(true)
  pointsPerDollar   Int     @default(1)
  signupBonus       Int     @default(50)
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  image     String   @default("")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id              String   @id @default(cuid())
  phone           String   @unique
  phoneVerified   Boolean  @default(false)
  name            String
  address         String?
  points          Int      @default(0)
  totalOrders     Int      @default(0)
  referralCode    String?  @unique
  referredByCode  String?
  referralPaidOut Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]
  
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id])
}

model ActiveSession {
  id              String   @id @default(cuid())
  sessionToken    String   @unique
  lastActiveAt    DateTime @default(now())
  cartTotal       Float    @default(0)
  itemCount       Int      @default(0)
  currentPath     String   @default("")
  checkoutName    String?
  checkoutPhone   String?
  checkoutAddress String?
}

// NextAuth Models

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  customer      Customer?
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
